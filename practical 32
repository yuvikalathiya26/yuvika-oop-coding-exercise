import java.util.LinkedList;

public class GenericSearch {

    public static <T> boolean searchElement(LinkedList<T> list, T element) {
        return list.contains(element);
    }

    public static void main(String[] args) {

        LinkedList<Integer> rollNumbers = new LinkedList<>();
        rollNumbers.add(101);
        rollNumbers.add(102);
        rollNumbers.add(103);
        rollNumbers.add(104);

        System.out.println("Roll Number Search:");
        System.out.println("Is 103 present? " + searchElement(rollNumbers, 103));
        System.out.println("Is 110 present? " + searchElement(rollNumbers, 110));

        LinkedList<String> names = new LinkedList<>();
        names.add("Alice");
        names.add("Bob");
        names.add("Charlie");
        names.add("David");

        System.out.println("\nName Search:");
        System.out.println("Is 'Bob' present? " + searchElement(names, "Bob"));
        System.out.println("Is 'Eve' present? " + searchElement(names, "Eve"));
    }
}
