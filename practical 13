import java.util.Scanner;

class Shape {
    double d1, d2;

    public void getData(double d1, double d2) {
        this.d1 = d1;
        this.d2 = d2;
    }
}

class Triangle extends Shape {

    public double calculateArea() {
        return 0.5 * d1 * d2;
    }
}

class Rectangle extends Shape {

    public double calculateArea() {
        return d1 * d2;
    }
}

public class ShapeDemo {
    public static void main(String[] args) {

        Scanner scanner = new Scanner(System.in);

        Triangle t = new Triangle();
        System.out.print("Enter base and height of triangle: ");
        double tb = scanner.nextDouble();
        double th = scanner.nextDouble();
        t.getData(tb, th);
        System.out.println("Area of Triangle: " + t.calculateArea());

        Rectangle r = new Rectangle();
        System.out.print("\nEnter length and width of rectangle: ");
        double rl = scanner.nextDouble();
        double rw = scanner.nextDouble();
        r.getData(rl, rw);
        System.out.println("Area of Rectangle: " + r.calculateArea());

        scanner.close();
    }
}
