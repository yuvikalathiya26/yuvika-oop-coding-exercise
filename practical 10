class BankAccount {
    private String accountHolderName;
    private double balance;

    static double interestRate = 0.05; // 5% interest

    public BankAccount(String name, double balance) {
        this.accountHolderName = name;
        this.balance = balance;
    }

    public double calculateInterest() {
        return balance * interestRate;
    }

    public void displayAccountDetails() {
        System.out.println("Account Holder: " + accountHolderName);
        System.out.println("Balance: " + balance);
        System.out.println("Interest Earned: " + calculateInterest());
        System.out.println();
    }

    public static void main(String[] args) {
        BankAccount acc1 = new BankAccount("Alice", 10000);
        BankAccount acc2 = new BankAccount("Bob", 20000);

        acc1.displayAccountDetails();
        acc2.displayAccountDetails();

        BankAccount.interestRate = 0.07; // 7%

        System.out.println("After updating interest rate:\n");

        acc1.displayAccountDetails();
        acc2.displayAccountDetails();
    }
}
